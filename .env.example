# ===================================================================
# StockSquad Configuration
# Copy this file to .env and fill in your actual values
# ===================================================================

# ===================================================================
# REQUIRED: Azure OpenAI Configuration
# ===================================================================
# Get your Azure OpenAI endpoint from: https://portal.azure.com
# Create a resource: Azure OpenAI Service
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# Authentication: Using DefaultAzureCredential (recommended)
# No API key needed if you're logged in via Azure CLI (az login)
# Alternatively, uncomment below to use API key:
# AZURE_OPENAI_API_KEY=<your-api-key>

# Deployment names (match what you created in Azure)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional: Alpha Vantage (if you want to use it instead of/alongside yfinance)
ALPHA_VANTAGE_API_KEY=<your-api-key>

# ===================================================================
# RECOMMENDED: Polygon.io (Fallback Data Source)
# ===================================================================
# Free tier: 500 requests/day - https://polygon.io
# Provides reliable fallback when yfinance data is missing
# Significantly improves ML pipeline reliability (70% → 95%+ success rate)
POLYGON_API_KEY=<your-api-key>

# ===================================================================
# OPTIONAL: Telegram Bot
# ===================================================================
# Create bot via @BotFather on Telegram
# Get token from BotFather after creating your bot
TELEGRAM_BOT_TOKEN=<your-bot-token>

# Optional: Restrict bot to specific chat/user
TELEGRAM_CHAT_ID=<your-chat-id>

# ===================================================================
# OPTIONAL: xAI Grok API (For SocialMediaAgent)
# ===================================================================
# Grok provides native X search and web search capabilities
# Get your API key from: https://console.x.ai
XAI_API_KEY=<your-xai-api-key>
# Model to use (default: grok-4-1-fast-reasoning)
# GROK_MODEL=grok-4-1-fast-reasoning

# ===================================================================
# Storage and Logging
# ===================================================================
# ChromaDB for long-term memory storage
CHROMA_DB_PATH=./chroma_db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
